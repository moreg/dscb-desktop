{
  "name": "ai-writer-desktop",
  "version": "0.1.0",
  "description": "大神持笔 桌面版（本地文件存储）",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "package": "electron-vite build && electron-builder",
    "icon": "node scripts/generate-wordmark-icon.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json"
  },
  "build": {
    "appId": "com.aiwriter.desktop",
    "productName": "大神持笔 桌面版",
    "icon": "build/icon.ico",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "node_modules/skia-canvas/**/*",
      "node_modules/zod/**/*"
    ],
    "asarUnpack": [
      "**/node_modules/skia-canvas/**/*"
    ],
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "@types/d3-force": "^3.0.10",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^31.0.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^2.3.0",
    "png-to-ico": "^3.0.1",
    "pngjs": "^7.0.0",
    "typescript": "^5.5.0",
    "vite": "^5.3.0",
    "vitest": "^2.0.0"
  },
  "dependencies": {
    "@floating-ui/react": "^0.27.20",
    "d3-force": "^3.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "skia-canvas": "^3.0.8",
    "zod": "^4.4.3"
  }
}
